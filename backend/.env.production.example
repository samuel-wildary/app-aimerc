PORT=3000
AIMERC_TOKEN_SECRET=troque-por-uma-chave-aleatoria-com-64-caracteres
# Use temporariamente durante rotacao de chave para manter sessoes antigas validas.
AIMERC_TOKEN_SECRET_PREVIOUS=
AIMERC_ALLOWED_ORIGINS=https://painel.seudominio.com.br,https://admin.seudominio.com.br
AIMERC_PUBLIC_API_URL=https://api.seudominio.com.br/api
# O container baixa uma vez e guarda no volume persistente /app/data.
AIMERC_AGENT_DOWNLOAD_URL=https://github.com/samuel-wildary/app-aimerc/releases/download/agent-v0.1.0/AiMerc-Agent-Setup.exe
AIMERC_AGENT_INSTALLER_PATH=/app/data/downloads/AiMerc-Agent-Setup.exe
AIMERC_SCRAPER_URL=http://aimerc-catalog-scraper:4300
AIMERC_TRUST_PROXY_HOPS=1
AIMERC_DB_POOL_MAX=10
AIMERC_ADMIN_NAME=Administrador AiMerc
AIMERC_ADMIN_EMAIL=admin@seudominio.com.br
AIMERC_ADMIN_PASSWORD=troque-por-uma-senha-forte-com-12-ou-mais-caracteres
FIREBASE_SERVICE_ACCOUNT_BASE64=JSON_DA_CONTA_FIREBASE_CODIFICADO_EM_BASE64

# PostgreSQL de producao. Nunca envie a senha ao GitHub.
# Prefira a rede privada do EasyPanel. Em conexao publica, exija TLS com sslmode=require.
DATABASE_URL=postgres://USUARIO:SENHA@HOST_INTERNO:5432/BANCO?sslmode=require
